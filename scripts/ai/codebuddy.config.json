{
  "default_model": "glm-5.2",
  "default_tools": "",
  "output_root": "var/ai_runs",
  "exhaustion_exit_code": 42,
  "credit_exhaustion_patterns": [
    "(?i)insufficient\\s+credits?",
    "(?i)not\\s+enough\\s+credits?",
    "(?i)credits?\\s+(exhausted|insufficient|used\\s+up)",
    "quota",
    "余额不足",
    "额度不足",
    "额度已用完",
    "额度耗尽"
  ],
  "patch_guard": {
    "allowed_extensions": [
      ".css",
      ".html",
      ".js",
      ".json",
      ".md",
      ".ps1",
      ".py",
      ".toml",
      ".txt",
      ".yaml",
      ".yml"
    ],
    "allowed_filenames": [
      ".env.example"
    ],
    "forbidden_path_patterns": [
      "(^|/)\\.env($|\\.(?!example$))",
      "(^|/)start\\.bat$",
      "(^|/)var/ai_runs/",
      "(^|/)logs/",
      "(^|/)uploads/",
      "(^|/)media/",
      "(^|/)staticfiles/",
      "(^|/)__pycache__/",
      "(^|/)\\.venv/",
      "(^|/)node_modules/",
      "(^|/)[^/]+/migrations/",
      "(?i)(^|/)(secrets?|passwords?)(\\.[^/]+)?$",
      "(?i)(^|/).*secret[_-]?key.*",
      "(?i)\\.pem$",
      "(?i)\\.key$"
    ]
  }
}
