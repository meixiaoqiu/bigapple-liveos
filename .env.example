# Big Apple Live OS Docker development environment example.
# Copy this file to .env and replace CHANGE_ME before running start.bat.

DATABASE_URL=mysql://big_apple_user:CHANGE_ME@mysql97:3306/big_apple_live?charset=utf8mb4
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,bigadmin.local,bigreal.local,bigsim.local
BIG_APPLE_CONTRACTS_ROOT=../big-apple-contracts

# Multi-database world routing. DATABASE_URL provides credentials and host;
# the DB_NAME variables swap only the database name.
BIG_APPLE_CONTROL_DB_NAME=dev_big_control
BIG_APPLE_REALWORLD_DB_NAME=dev_big_real
BIG_APPLE_SIMULATION0001_DB_NAME=dev_big_sim0001
BIG_APPLE_WORLD_DATABASE_ALIASES=realworld,simulation0001
BIG_APPLE_DEFAULT_WORLD_DATABASE_ALIAS=realworld

# Example for adding another configured simulation world:
# BIG_APPLE_WORLD_DATABASE_ALIASES=realworld,simulation0001,simulation0002
# BIG_APPLE_SIMULATION0002_DB_NAME=dev_big_sim0002

# start.bat expects an existing mysql97 container and nginx container on dev-net.
